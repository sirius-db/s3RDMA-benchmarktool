# Pinned third-party NVIDIA SDK versions, consumed by scripts/fetch_sdk.sh.
# These SDKs are NVIDIA-proprietary and are NOT redistributed in this repo; the
# fetch script downloads them at build time into third_party/ (gitignored).
#
# Override any of these in the environment to point at a local copy or mirror.

# cuObject SDK (cuObjClient / cuObjServer RDMA data path).
CUOBJ_VERSION="1.0.0"
# cuFile / GPUDirect Storage. cuObject 1.0.0 pairs with cufile 1.16; the client
# node's stock cufile (1.15) has an incompatible object API, so the matched
# version is fetched and loaded first in the deploy bundle (see scripts/bundle.sh).
CUFILE_VERSION="1.16"

# Download locations. These are intentionally left blank because the cuObject SDK
# is gated behind NVIDIA's developer program — set them to the URLs you were given
# (or to an internal mirror) before running `pixi run fetch-sdk`. The fetch script
# errors with guidance if they are unset. Alternatively, point CUOBJ_SDK_ROOT at an
# already-unpacked SDK tree and skip the download entirely.
CUOBJ_SDK_URL="${CUOBJ_SDK_URL:-}"
CUFILE_URL="${CUFILE_URL:-}"

# Optional SHA256 checksums for integrity verification (recommended for mirrors).
CUOBJ_SDK_SHA256="${CUOBJ_SDK_SHA256:-}"
CUFILE_SHA256="${CUFILE_SHA256:-}"
